# ─────────────────────────────────────────────────────────────────────────────
# Kasa — environment variable NAMES only. NEVER put real values in this file.
# Copy to `.env.local` (gitignored) and fill in real values there.
# In production, these live in Supabase Edge Function secrets, not in a file.
# See DECISIONS.md, ARCHITECTURE.md, INTEGRATIONS.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Postgres + Auth + RLS + Realtime) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only; bypasses RLS. Never ship to a client.

# ── Square (booking) — keep SANDBOX until launch (DECISIONS.md) ──────────────
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_ENVIRONMENT=sandbox         # sandbox | production  (default sandbox)
SQUARE_REDIRECT_URL=               # OAuth callback URL

# ── Encryption (AES-256-GCM for Square tokens stored in Supabase) ───────────
ENCRYPTION_KEY=                    # 32+ chars. Rotate if compromised. Never commit.

# ── AI booking-intent parser — Anthropic Claude (Haiku) is the ONLY provider ─
# (Groq was dropped — see DECISIONS.md "out of scope". Do not reintroduce.)
AI_ENABLED=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # optional override
AI_DEBUG_MODE=false

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=

# ─────────────────────────────────────────────────────────────────────────────
# CHANNELS — added per INTEGRATIONS.md. Fill in as each channel is built
# (Phase 4). Inbound webhooks live on Supabase Edge Functions on a STABLE URL.
# ─────────────────────────────────────────────────────────────────────────────

# SMS — Twilio (build first; no reply-window limit)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=                 # also used to verify inbound webhook signatures
TWILIO_PHONE_NUMBER=

# Instagram — Meta Graph API (start App Review early)
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=        # you choose this; Meta echoes it on setup
META_PAGE_ACCESS_TOKEN=

# WeChat — Official Account (Service Account, 48h service window)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_WEBHOOK_TOKEN=             # for signature verification + challenge echo

# KakaoTalk — Channel via partner/BSP (scope last)
KAKAO_REST_API_KEY=
KAKAO_CHANNEL_ID=
KAKAO_BSP_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OUT OF SCOPE for the new app (DECISIONS.md). Listed so nobody re-adds them by
# accident. Leave unset unless email / SMS-reminders are deliberately revived.
#   RESEND_API_KEY=
#   RESEND_FROM_EMAIL=
#   GROQ_API_KEY=
#   GROQ_MODEL=
# ─────────────────────────────────────────────────────────────────────────────
